#VAR

def calculateVaR(risk, confidenceLevel, principal = 1, numMonths = 1):
    vol = math.sqrt(risk)
    return abs(principal * norm.ppf(1-confidenceLevel, 0, 1) * vol * math.sqrt(numMonths))

